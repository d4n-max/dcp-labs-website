{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/textsense/privacy",
      "destination": "/textsense-privacy-policy",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/textsense-privacy-policy",
      "destination": "/textsense-privacy-policy.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
